{
    "name": "ai-task-orchestrator",
    "displayName": "AI Task Orchestrator",
    "description": "AI-powered task orchestrator for VS Code",
    "version": "0.1.0",
    "publisher": "YusufEnesKarahan",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/YusufEnesKarahan/AI_Task__Orchestrator.git"
    },
    "bugs": {
        "url": "https://github.com/YusufEnesKarahan/AI_Task__Orchestrator/issues"
    },
    "homepage": "https://github.com/YusufEnesKarahan/AI_Task__Orchestrator#readme",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Machine Learning",
        "Other"
    ],
    "keywords": [
        "ai",
        "task-orchestration",
        "prompt",
        "workflow",
        "openai",
        "gemini"
    ],
    "activationEvents": [
        "onCommand:ai-task-orchestrator.openPanel",
        "onView:ai-task-orchestrator.sidebar"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "ai-task-orchestrator.openPanel",
                "title": "AI Task Orchestrator: Open Panel"
            },
            {
                "command": "ai-task-orchestrator.setOpenAIApiKey",
                "title": "AI Task Orchestrator: Set OpenAI API Key"
            },
            {
                "command": "ai-task-orchestrator.setGeminiApiKey",
                "title": "AI Task Orchestrator: Set Gemini API Key"
            }
        ],
        "configuration": {
            "title": "AI Task Orchestrator",
            "properties": {
                "aiTaskOrchestrator.provider": {
                    "type": "string",
                    "enum": [
                        "openai",
                        "gemini",
                        "mock"
                    ],
                    "default": "openai",
                    "description": "Explicit provider selection. Mock mode is only used when selected here."
                },
                "aiTaskOrchestrator.openAiModel": {
                    "type": "string",
                    "default": "gpt-4o-mini",
                    "description": "Model name used when the OpenAI provider is selected."
                },
                "aiTaskOrchestrator.geminiModel": {
                    "type": "string",
                    "default": "gemini-1.5-flash",
                    "description": "Model name used when the Gemini provider is selected."
                },
                "aiTaskOrchestrator.timeoutMs": {
                    "type": "number",
                    "default": 30000,
                    "minimum": 1000,
                    "description": "Request timeout for AI provider calls in milliseconds."
                },
                "aiTaskOrchestrator.maxRetries": {
                    "type": "number",
                    "default": 2,
                    "minimum": 0,
                    "description": "Maximum retry count for retryable provider failures."
                }
            }
        },
        "views": {
            "explorer": [
                {
                    "id": "ai-task-orchestrator.sidebar",
                    "name": "AI Task Orchestrator"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "ai-task-orchestrator.openPanel",
                    "when": "view == ai-task-orchestrator.sidebar",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "clean:out": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"if (Test-Path out) { Remove-Item -LiteralPath out -Recurse -Force }\"",
        "compile": "npm run clean:out && tsc -p ./",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "package": "vsce package",
        "test": "tsc -p ./tsconfig.test.json && node --test \"out-test/test/*.test.js\"",
        "watch": "tsc -watch -p ./"
    },
    "dependencies": {
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "18.x",
        "@types/vscode": "^1.80.0",
        "@vscode/vsce": "^3.9.1",
        "eslint": "^10.4.0",
        "prettier": "^3.8.3",
        "typescript": "^5.1.3",
        "typescript-eslint": "^8.59.3"
    }
}
